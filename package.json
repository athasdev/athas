{
  "name": "athas",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bunx vp test run",
    "typecheck": "tsc --noEmit",
    "check": "bash scripts/check.sh",
    "check:frontend": "bash scripts/check/frontend.sh",
    "lint": "bunx vp lint .",
    "fix": "bunx vp check --fix",
    "format": "bunx vp fmt --write .",
    "check:rust": "bun scripts/check-zig.ts && bash scripts/check/rust.sh",
    "reset:workspace": "concurrently --names \"node,rust\" --prefix-colors \"cyan,yellow\" \"rimraf dist build node_modules bun.lockb && bun install\" \"cargo clean && cargo build\"",
    "postinstall": "bun scripts/postinstall.ts",
    "prepare": "simple-git-hooks",
    "commitlint": "commitlint",
    "setup": "bun scripts/setup.ts",
    "dev": "bun scripts/check-zig.ts && WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev --config src-tauri/tauri.preview.conf.json",
    "dev:stable": "bun scripts/check-zig.ts && WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev",
    "dev:preview": "bun scripts/check-zig.ts && WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev --config src-tauri/tauri.preview.conf.json",
    "dev:linux": "bun scripts/check-zig.ts && cargo tauri dev --config src-tauri/tauri.dev.conf.json -- --no-default-features --features linux -- --ozone-platform=x11 --disable-vulkan --disable-features=Vulkan",
    "build:stable": "bun scripts/check-zig.ts && tauri build",
    "build:linux": "bun scripts/check-zig.ts && cargo tauri build --no-bundle -- --no-default-features --features linux && bash scripts/release/package-linux-tarball.sh $(uname -m) release-dist",
    "build:linux:deb": "bash scripts/release/package-linux-native.sh deb",
    "build:linux:rpm": "bash scripts/release/package-linux-native.sh rpm",
    "build:linux:appimage": "bash scripts/release/package-linux-native.sh appimage",
    "build:linux:native": "bash scripts/release/package-linux-native.sh all",
    "build:preview": "bun scripts/check-zig.ts && tauri build --config src-tauri/tauri.preview.conf.json",
    "build:dev": "bun scripts/check-zig.ts && tauri build --config src-tauri/tauri.dev.conf.json",
    "smoke:macos": "bun scripts/smoke-app.ts --platform macos",
    "smoke:linux": "bun scripts/smoke-app.ts --platform linux",
    "smoke:windows": "bun scripts/smoke-app.ts --platform windows",
    "pre-commit": "bun scripts/hooks/pre-commit.ts",
    "release:check": "bun scripts/release/pre-release-check.ts",
    "release:verify": "bun scripts/release/release-assets.mjs verify --repo athasdev/athas",
    "release:repair-plan": "bun scripts/release/release-assets.mjs repair-plan --repo athasdev/athas",
    "release": "bun scripts/release.ts stable patch",
    "release:stable": "bun scripts/release.ts stable patch",
    "release:preview": "bun scripts/release.ts preview patch",
    "release:patch": "bun scripts/release.ts stable patch",
    "release:minor": "bun scripts/release.ts stable minor",
    "release:major": "bun scripts/release.ts stable major",
    "release:preview:patch": "bun scripts/release.ts preview patch",
    "release:preview:minor": "bun scripts/release.ts preview minor",
    "release:preview:major": "bun scripts/release.ts preview major",
    "extensions:stage": "bun src/features/extensions/scripts/stage-cdn-assets.ts",
    "extensions:package": "bun src/features/extensions/scripts/package-extensions.ts",
    "extensions:package:databases": "bun src/features/extensions/scripts/package-database-sidecars.ts",
    "extensions:catalog": "bun src/features/extensions/scripts/build-extensions-index.ts && bun src/features/extensions/scripts/generate-manifests.ts",
    "extensions:prepare": "bun run extensions:package && bun run extensions:stage && bun run extensions:catalog",
    "extensions:validate": "bun src/features/extensions/scripts/validate.ts",
    "extensions:index:check": "bun src/features/extensions/scripts/build-extensions-index.ts --check",
    "extensions:verify-cdn": "bun src/features/extensions/scripts/verify-installable-packages.ts",
    "extensions:deploy": "bun src/features/extensions/scripts/deploy-extensions-cdn.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.14.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^12.42.0",
    "ignore": "^7.0.5",
    "immer": "^11.1.8",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "nanoid": "^5.1.16",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-pdf": "^10.4.1",
    "react-scan": "^0.5.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.1",
    "use-sync-external-store": "^1.6.0",
    "usehooks-ts": "^3.1.1",
    "vscode-languageserver-protocol": "^3.18.1",
    "vscode-languageserver-types": "^3.18.0",
    "web-tree-sitter": "^0.26.9",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@derekstride/tree-sitter-sql": "^0.3.11",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@tlaplus/tree-sitter-tlaplus": "^1.5.0",
    "@tree-sitter-grammars/tree-sitter-markdown": "^0.3.2",
    "@tree-sitter-grammars/tree-sitter-vue": "github:tree-sitter-grammars/tree-sitter-vue",
    "@tree-sitter-grammars/tree-sitter-yaml": "^0.7.1",
    "@tree-sitter-grammars/tree-sitter-zig": "^1.1.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@voidzero-dev/vite-plus-core": "^0.2.1",
    "bun-types": "^1.3.14",
    "code-inspector-plugin": "^1.6.2",
    "concurrently": "^10.0.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.1",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cli": "^0.26.9",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-css": "^0.25.0",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-diff": "github:the-mikedavis/tree-sitter-diff",
    "tree-sitter-elisp": "^1.6.1",
    "tree-sitter-elixir": "^0.3.5",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-lua": "^2.1.3",
    "tree-sitter-objc": "^3.0.2",
    "tree-sitter-ocaml": "^0.24.2",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rescript": "github:rescript-lang/tree-sitter-rescript",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-solidity": "^1.2.13",
    "tree-sitter-svelte": "0.11.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-systemrdl": "^0.8.0",
    "tree-sitter-toml": "^0.5.1",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
    "vite-plus": "^0.2.1"
  },
  "overrides": {
    "next": "15.5.19",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  },
  "simple-git-hooks": {
    "pre-commit": "bun pre-commit",
    "commit-msg": "bun commitlint --edit $1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.2"
}
