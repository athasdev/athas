{
  "name": "athas",
  "version": "0.4.7",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bunx vp test run",
    "typecheck": "tsc --noEmit",
    "check": "bash scripts/check.sh",
    "check:frontend": "bash scripts/check/frontend.sh",
    "lint": "bunx vp lint .",
    "fix": "bunx vp check --fix",
    "format": "bunx vp fmt --write .",
    "check:rust": "bun scripts/check-zig.ts && bash scripts/check/rust.sh",
    "reset:workspace": "concurrently --names \"node,rust\" --prefix-colors \"cyan,yellow\" \"rimraf dist build node_modules bun.lockb && bun install\" \"cargo clean && cargo build\"",
    "postinstall": "bun scripts/postinstall.ts",
    "prepare": "simple-git-hooks",
    "commitlint": "commitlint",
    "setup": "bun scripts/setup.ts",
    "dev": "bun scripts/check-zig.ts && WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev --config src-tauri/tauri.dev.conf.json",
    "dev:stable": "bun scripts/check-zig.ts && WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev",
    "dev:preview": "bun scripts/check-zig.ts && WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev --config src-tauri/tauri.preview.conf.json",
    "dev:linux": "bun scripts/check-zig.ts && cargo tauri dev --config src-tauri/tauri.dev.conf.json -- --no-default-features --features linux",
    "build:stable": "bun scripts/check-zig.ts && tauri build",
    "build:linux": "bun scripts/check-zig.ts && cargo tauri build --no-bundle -- --no-default-features --features linux && bash scripts/release/package-linux-tarball.sh $(uname -m) release-dist",
    "build:preview": "bun scripts/check-zig.ts && tauri build --config src-tauri/tauri.preview.conf.json",
    "build:dev": "bun scripts/check-zig.ts && tauri build --config src-tauri/tauri.dev.conf.json",
    "smoke": "bun scripts/smoke-app.ts",
    "smoke:stable": "bun scripts/smoke-app.ts stable",
    "smoke:preview": "bun scripts/smoke-app.ts preview",
    "pre-commit": "bun scripts/hooks/pre-commit.ts",
    "release:check": "bun scripts/release/pre-release-check.ts",
    "release:verify": "bun scripts/release/release-assets.mjs verify --repo athasdev/athas",
    "release:repair-plan": "bun scripts/release/release-assets.mjs repair-plan --repo athasdev/athas",
    "release": "bun scripts/release.ts stable patch",
    "release:stable": "bun scripts/release.ts stable patch",
    "release:preview": "bun scripts/release.ts preview patch",
    "release:patch": "bun scripts/release.ts stable patch",
    "release:minor": "bun scripts/release.ts stable minor",
    "release:major": "bun scripts/release.ts stable major",
    "release:preview:patch": "bun scripts/release.ts preview patch",
    "release:preview:minor": "bun scripts/release.ts preview minor",
    "release:preview:major": "bun scripts/release.ts preview major"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.12",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.5",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-http": "^2.5.4",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@tauri-apps/plugin-store": "~2.4.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^12.34.3",
    "ignore": "^7.0.5",
    "immer": "^10.2.0",
    "material-file-icons": "^2.4.0",
    "nanoid": "^3.3.11",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-pdf": "^10.3.0",
    "react-scan": "^0.4.3",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.0.6",
    "use-sync-external-store": "^1.6.0",
    "usehooks-ts": "^3.1.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "web-tree-sitter": "^0.25.10",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@derekstride/tree-sitter-sql": "^0.3.11",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2.10.1",
    "@tlaplus/tree-sitter-tlaplus": "^1.0.0",
    "@tree-sitter-grammars/tree-sitter-markdown": "^0.3.0",
    "@tree-sitter-grammars/tree-sitter-vue": "github:tree-sitter-grammars/tree-sitter-vue",
    "@tree-sitter-grammars/tree-sitter-yaml": "^0.7.0",
    "@tree-sitter-grammars/tree-sitter-zig": "^1.0.0",
    "@types/bun": "^1.3.3",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@voidzero-dev/vite-plus-core": "^0.1.11",
    "code-inspector-plugin": "^1.3.0",
    "concurrently": "^9.2.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.17",
    "tree-sitter-bash": "^0.23.0",
    "tree-sitter-c": "^0.23.0",
    "tree-sitter-c-sharp": "^0.23.0",
    "tree-sitter-cli": "^0.26.6",
    "tree-sitter-cpp": "^0.23.0",
    "tree-sitter-css": "^0.23.0",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-diff": "github:the-mikedavis/tree-sitter-diff",
    "tree-sitter-elisp": "^1.0.0",
    "tree-sitter-elixir": "^0.3.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-html": "^0.23.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-json": "^0.24.0",
    "tree-sitter-kotlin": "^0.3.0",
    "tree-sitter-lua": "^2.0.0",
    "tree-sitter-objc": "^3.0.0",
    "tree-sitter-ocaml": "^0.23.0",
    "tree-sitter-php": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-rescript": "github:rescript-lang/tree-sitter-rescript",
    "tree-sitter-ruby": "^0.23.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-scala": "^0.23.0",
    "tree-sitter-solidity": "^1.0.0",
    "tree-sitter-svelte": "0.11.0",
    "tree-sitter-swift": "^0.6.0",
    "tree-sitter-systemrdl": "^0.8.0",
    "tree-sitter-toml": "^0.5.0",
    "tree-sitter-typescript": "^0.23.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^4.4.1",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.11",
    "vite-plus": "^0.1.11"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.11",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.11"
  },
  "simple-git-hooks": {
    "pre-commit": "bun pre-commit",
    "commit-msg": "bun commitlint --edit $1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.2"
}
