{
  "$schema": "https://athas.dev/schemas/extension.json",
  "id": "athas.agent.kimi-cli",
  "name": "Kimi CLI",
  "displayName": "Kimi CLI",
  "description": "Moonshot's Kimi command-line agent with native ACP support.",
  "version": "1.0.0",
  "publisher": "Moonshot AI",
  "categories": ["Agent"],
  "agents": [
    {
      "id": "kimi-cli",
      "name": "Kimi CLI",
      "binaryName": "kimi",
      "description": "Moonshot Kimi Code CLI agent with native ACP support.",
      "args": ["acp"],
      "install": {
        "runtime": "binary",
        "package": "kimi-cli",
        "command": "kimi",
        "downloadUrls": {
          "darwin-arm64": "https://github.com/MoonshotAI/kimi-cli/releases/download/1.41.0/kimi-1.41.0-aarch64-apple-darwin.tar.gz",
          "linux-arm64": "https://github.com/MoonshotAI/kimi-cli/releases/download/1.41.0/kimi-1.41.0-aarch64-unknown-linux-gnu.tar.gz",
          "linux-x64": "https://github.com/MoonshotAI/kimi-cli/releases/download/1.41.0/kimi-1.41.0-x86_64-unknown-linux-gnu.tar.gz",
          "win32-arm64": "https://github.com/MoonshotAI/kimi-cli/releases/download/1.41.0/kimi-1.41.0-aarch64-pc-windows-msvc.zip",
          "win32-x64": "https://github.com/MoonshotAI/kimi-cli/releases/download/1.41.0/kimi-1.41.0-x86_64-pc-windows-msvc.zip"
        }
      }
    }
  ]
}
