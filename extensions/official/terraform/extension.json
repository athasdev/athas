{
  "$schema": "https://athas.dev/schemas/extension.json",
  "id": "athas.terraform",
  "name": "Terraform",
  "displayName": "Terraform",
  "version": "1.0.0",
  "description": "Terraform and HCL language support with LSP",
  "publisher": "Athas",
  "categories": ["Language"],
  "languages": [
    {
      "id": "terraform",
      "extensions": [".tf", ".tfvars"],
      "aliases": ["Terraform", "HCL", "hcl"]
    }
  ],
  "capabilities": {
    "lsp": {
      "name": "terraform-ls",
      "runtime": "binary",
      "args": ["serve"]
    }
  }
}
